# ============================================================================
# Vape 2 Go — variables de entorno
# ----------------------------------------------------------------------------
# Copia este archivo a `.env.local` (gitignored) y llena los valores.
# En producción, configúralas en Netlify → Site settings → Environment variables.
#
# Regla: las `NEXT_PUBLIC_*` se exponen al navegador (seguras de exponer).
#        Las demás son SECRETAS y solo viven en el backend (Netlify Functions / n8n).
# ============================================================================

# --- Supabase (auth + base de datos + RLS) ---------------------------------
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SECRETA — ignora RLS. Solo en Netlify Functions / n8n. NUNCA con prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (SMTP de confirmación en Supabase + futuros correos de órdenes) -
# El API key se usa como password del SMTP en Supabase (host smtp.resend.com).
RESEND_API_KEY=
RESEND_FROM=noreply@vapes.do

# --- Analítica de producto (PostHog) — opcional ----------------------------
# Dashboard PostHog → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Monitoreo de errores (Sentry) — opcional ------------------------------
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ENV=production

# --- Protección anti-bot (Cloudflare Turnstile) — recomendado --------------
# https://dash.cloudflare.com → Turnstile → Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Alertas de monitoreo (webhook a n8n / Discord / Telegram) -------------
# Lo usa netlify/functions/healthcheck para avisar si algo se cae.
ALERT_WEBHOOK_URL=
